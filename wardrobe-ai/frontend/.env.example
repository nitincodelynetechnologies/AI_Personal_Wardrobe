# Browser → NestJS API
# Local dev: `/api` (Next.js proxies to localhost:3001).
# Production / static export (`out/`): MUST be absolute — rewrites and /api routes do not exist.
NEXT_PUBLIC_API_BASE_URL=/api
# Alias for the same value (optional):
# NEXT_PUBLIC_BACKEND_API_URL=https://ai-personal-wardrobe.onrender.com/api
# Production build (Render / static export) — set before `npm run build`:
# NEXT_PUBLIC_API_BASE_URL=https://ai-personal-wardrobe.onrender.com/api
BACKEND_API_URL=http://localhost:3001/api

# Python IDM-VTON — local dev uses Next.js /vton-api rewrite → localhost:8010
NEXT_PUBLIC_VTON_API_URL=/vton-api
# Production / static export — absolute VTON service URL (no Next.js proxy):
# NEXT_PUBLIC_VTON_API_URL=https://your-vton-service.onrender.com
# NEXT_PUBLIC_VTON_BACKEND_URL=https://your-vton-service.onrender.com
VTON_BACKEND_URL=http://127.0.0.1:8010

# Comma-separated admin emails (backend ADMIN_EMAILS — no frontend rebuild needed)
ADMIN_EMAILS=patel12@gmail.com,patel@gmail.com
# Optional frontend allowlist (requires rebuild if changed):
NEXT_PUBLIC_ADMIN_EMAILS=patel12@gmail.com,patel@gmail.com

# Optional: enable live LLM replies in Customer Support chat (falls back to keyword engine if unset)
NEXT_PUBLIC_SUPPORT_OPENAI_API_KEY=
