# Browser calls backend directly on Render (avoids broken /api proxy for multipart uploads).
# Local dev: keep /api so Next.js proxies to localhost:3001.
NEXT_PUBLIC_API_BASE_URL=/api
# Optional production override (must be set before build if you use a custom backend host):
# NEXT_PUBLIC_API_BASE_URL=https://ai-personal-wardrobe.onrender.com/api
BACKEND_API_URL=http://localhost:3001/api

# Python IDM-VTON — proxied in dev via Next.js /vton-api → localhost:8010 (start.ps1 default)
NEXT_PUBLIC_VTON_API_URL=/vton-api
VTON_BACKEND_URL=http://127.0.0.1:8010

# Comma-separated admin emails (backend ADMIN_EMAILS — no frontend rebuild needed)
ADMIN_EMAILS=patel12@gmail.com,patel@gmail.com
# Optional frontend allowlist (requires rebuild if changed):
NEXT_PUBLIC_ADMIN_EMAILS=patel12@gmail.com,patel@gmail.com

# Optional: enable live LLM replies in Customer Support chat (falls back to keyword engine if unset)
NEXT_PUBLIC_SUPPORT_OPENAI_API_KEY=
