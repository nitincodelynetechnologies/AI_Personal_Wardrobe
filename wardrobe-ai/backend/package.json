{
  "name": "@wardrobe-ai/backend",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS API Gateway for AI Personal Wardrobe Platform",
  "scripts": {
    "build": "node -e \"try{require('fs').unlinkSync('tsconfig.tsbuildinfo')}catch(e){}\" && node ./node_modules/@nestjs/cli/bin/nest.js build",
    "start": "node dist/main.js",
    "start:dev": "node ./node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
