# Set to false for real Hugging Face IDM-VTON inference (2–5 min per request)
VTON_MOCK=true
# When real AI fails (no HF GPU, queue busy), return dev pairing instead of error
VTON_GPU_FALLBACK=true
# Hugging Face access token — bypasses strict unauthenticated ZeroGPU quota (create at huggingface.co/settings/tokens)
HF_TOKEN=
