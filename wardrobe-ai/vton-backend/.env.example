# Set to false for real Hugging Face IDM-VTON inference (2–5 min per request)
VTON_MOCK=true
# When real AI fails (no HF GPU, queue busy), return dev pairing instead of error
VTON_GPU_FALLBACK=true
# Hugging Face access token (required for real IDM-VTON — NOT passed to Client() in code).
# Create at https://huggingface.co/settings/tokens and paste here:
HF_TOKEN=your_hf_token_here
