# =============================================================================
# AI Personal Wardrobe Platform — Unified Environment Configuration
# Copy to .env at the repository root:  cp .env.example .env
#
# Local dev (npm run dev): use localhost hostnames below.
# Docker Compose stack:    service hostnames are injected in docker-compose.yml
#                            (postgres, qdrant, face-service, stylist-service, backend).
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=production
COMPOSE_PROJECT_NAME=wardrobe-ai

# -----------------------------------------------------------------------------
# Host ports (Docker Compose maps these to containers)
# -----------------------------------------------------------------------------
FRONTEND_PORT=3000
API_PORT=3001
POSTGRES_PORT=5432
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
FACE_SERVICE_PORT=8000
STYLIST_SERVICE_PORT=8001

# Optional: expose NestJS on host port 5000 instead of 3001
# API_PORT=5000

# -----------------------------------------------------------------------------
# PostgreSQL (Relational Data)
# -----------------------------------------------------------------------------
POSTGRES_USER=wardrobe_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=wardrobe_db

# Local npm dev — point at Docker postgres on localhost
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://wardrobe_user:change_me_postgres_password@localhost:5432/wardrobe_db

# -----------------------------------------------------------------------------
# Qdrant (Vector Embeddings)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_FACES=users_face_vectors
QDRANT_COLLECTION_FASHION_DNA=fashion_dna_vectors
QDRANT_COLLECTION_RECOMMENDATIONS=recommendation_vectors
QDRANT_COLLECTION_CLOTHING_ITEMS=clothing_item_vectors
QDRANT_FACE_VECTOR_SIZE=512
QDRANT_FASHION_DNA_VECTOR_SIZE=512
QDRANT_RECOMMENDATION_VECTOR_SIZE=512
QDRANT_CLOTHING_ITEM_VECTOR_SIZE=512
QDRANT_SIMILARITY_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# Authentication (JWT & Face Login)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
FACE_SERVICE_MOCK=false
FACE_SERVICE_TIMEOUT_MS=10000
FACE_LOGIN_SIMILARITY_THRESHOLD=0.55

# Local npm dev — AI service URLs on localhost
FACE_SERVICE_HOST=localhost
FACE_SERVICE_URL=http://localhost:8000
FACE_MODEL_NAME=buffalo_l
MAX_IMAGE_SIZE_MB=10
INSIGHTFACE_CTX_ID=-1

# -----------------------------------------------------------------------------
# Stylist / Wardrobe AI (Python)
# -----------------------------------------------------------------------------
STYLIST_MOCK=false
EMBEDDING_SIZE=512
STYLIST_SERVICE_HOST=localhost
STYLIST_SERVICE_URL=http://localhost:8001
PYTHON_STYLIST_URL=http://localhost:8001
STYLIST_SERVICE_TIMEOUT_MS=15000
STYLIST_BG_REMOVAL_TIMEOUT_MS=45000

# -----------------------------------------------------------------------------
# Wardrobe Uploads (NestJS)
# -----------------------------------------------------------------------------
WARDROBE_UPLOAD_DIR=./uploads/wardrobe
WARDROBE_MAX_FILE_SIZE_MB=5

# -----------------------------------------------------------------------------
# NestJS API Gateway
# -----------------------------------------------------------------------------
API_HOST=localhost
API_BASE_URL=http://localhost:3001/api

# Comma-separated browser origins allowed by CORS (add your domain in production)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3003

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
# Browser calls /api; Next.js rewrites to the NestJS gateway (see next.config.js)
NEXT_PUBLIC_API_BASE_URL=/api

# Server-side rewrite target — Docker Compose overrides to http://backend:3001/api
BACKEND_API_URL=http://localhost:3001/api

# Local npm dev port (docker uses FRONTEND_PORT=3000)
FRONTEND_DEV_PORT=3003

# -----------------------------------------------------------------------------
# Optional / Future Infrastructure (not in core 6-service stack)
# -----------------------------------------------------------------------------
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=change_me_redis_password
# MINIO_ROOT_USER=minio_admin
# MINIO_ROOT_PASSWORD=change_me_minio_password
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_BUCKET_WARDROBE=wardrobe-assets
# MINIO_BUCKET_FACES=face-captures
