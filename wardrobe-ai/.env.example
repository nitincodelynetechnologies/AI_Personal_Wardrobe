# =============================================================================
# AI Personal Wardrobe Platform — Local-First Environment Configuration
# Copy this file to .env and adjust values for your local machine.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Relational Data)
# -----------------------------------------------------------------------------
POSTGRES_USER=wardrobe_user
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=wardrobe_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# -----------------------------------------------------------------------------
# Redis (Caching & Sessions)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# -----------------------------------------------------------------------------
# Qdrant (Vector Embeddings — face vectors, style embeddings)
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_URL=http://${QDRANT_HOST}:${QDRANT_PORT}
QDRANT_COLLECTION_FACES=users_face_vectors
QDRANT_COLLECTION_STYLE=style_embeddings
QDRANT_FACE_VECTOR_SIZE=512

# -----------------------------------------------------------------------------
# MinIO (Local S3-Compatible Object Storage)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET_WARDROBE=wardrobe-assets
MINIO_BUCKET_FACES=face-captures
MINIO_ENDPOINT=http://${MINIO_HOST}:${MINIO_PORT}
MINIO_USE_SSL=false

# -----------------------------------------------------------------------------
# Authentication (JWT)
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
FACE_SERVICE_MOCK=true
QDRANT_SIMILARITY_THRESHOLD=0.75

# -----------------------------------------------------------------------------
# Backend API (NestJS)
# -----------------------------------------------------------------------------
API_HOST=localhost
API_PORT=3001
API_BASE_URL=http://${API_HOST}:${API_PORT}/api

# -----------------------------------------------------------------------------
# Frontend (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
FRONTEND_PORT=3003

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
FACE_SERVICE_HOST=localhost
FACE_SERVICE_PORT=8000
FACE_SERVICE_URL=http://${FACE_SERVICE_HOST}:${FACE_SERVICE_PORT}

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
COMPOSE_PROJECT_NAME=wardrobe-ai
